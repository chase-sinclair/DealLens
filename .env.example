# DealLens environment template
# Copy this file to .env and fill values locally.
# Never commit .env or real secrets.

# OpenAI
OPENAI_API_KEY=

# Slack
# Use either a bot token or webhook depending on the Zapier/Slack setup.
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL_ID=

# Airtable
AIRTABLE_PERSONAL_ACCESS_TOKEN=
AIRTABLE_BASE_ID=

# Google Drive / Docs
GOOGLE_DRIVE_INTAKE_FOLDER_ID=
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=
GOOGLE_DOCS_MEMO_TEMPLATE_ID=

# PDF extraction
# PDF.co is the default extraction provider for the MVP.
PDFCO_API_KEY=
DOCPARSER_API_KEY=
DOCPARSER_PARSER_ID=

# DealLens project config
DEALLENS_PROJECT_NAME=DealLens
DEALLENS_DEFAULT_MANUAL_REVIEW_MINUTES=75
DEALLENS_DEFAULT_ANALYST_OWNER=
DEALLENS_DEFAULT_PE_THESIS=B2B services
